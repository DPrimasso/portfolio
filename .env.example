# Environment Variables Template
# Copia questo file come .env e compila i valori

# URL pubblico del sito (senza slash finale). Obbligatorio in build di produzione per
# robots.txt, sitemap.xml, immagini OG assolute e JSON-LD.
# VITE_BASE_URL=https://www.danieleprimasso.it

# OpenAI API Key (solo per sviluppo locale, in produzione usa serverless function)
# VITE_APP_OPENAI_API_KEY=your_openai_api_key_here

# Chatbot API URL (opzionale, default: /api/chatbot)
# VITE_CHATBOT_API_URL=https://your-domain.com/api/chatbot

# Per Netlify/Vercel, configura OPENAI_API_KEY nelle variabili ambiente della piattaforma
# Non aggiungere mai le chiavi API nei file committati!

# Firebase — Academy platform
# Crea un progetto su https://console.firebase.google.com e copia le credenziali
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Academy — chi vede quali corsi: in Firestore, `users/{uid}.enrolledCourses` è un array di id
# (es. programmazione-base). Se è vuoto, l'utente non vede corsi finché non aggiungi quell'array in console Firebase.
# Opzioni per anteprima / admin senza toccare Firestore:
# VITE_ACADEMY_ALL_COURSES=true
#   → tutti gli utenti vedono tutti i corsi del catalogo (solo sviluppo).
# VITE_ACADEMY_ADMIN_EMAILS=admin@tuodominio.it,altro@email.it
#   → solo queste email (match case-insensitive) vedono tutto il catalogo.
